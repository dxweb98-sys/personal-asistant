{
  "name": "personal-finance-os",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "prisma generate && tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio",
    "test": "vitest run"
  },
  "dependencies": {
    "@prisma/adapter-pg": "7.8.0",
    "@prisma/client": "7.8.0",
    "cors": "2.8.5",
    "dotenv": "17.2.3",
    "express": "5.2.1",
    "helmet": "8.1.0",
    "morgan": "1.10.1",
    "pg": "8.16.3",
    "zod": "4.4.3",
    "telegraf": "4.16.3",
    "exceljs": "4.4.0",
    "pdfkit": "0.17.2"
  },
  "devDependencies": {
    "@types/cors": "2.8.19",
    "@types/express": "5.0.6",
    "@types/morgan": "1.9.10",
    "@types/node": "24.10.1",
    "@types/pg": "8.15.6",
    "prisma": "7.8.0",
    "tsx": "4.20.6",
    "typescript": "7.0.2",
    "vitest": "4.0.15",
    "@types/pdfkit": "0.17.4"
  }
}
